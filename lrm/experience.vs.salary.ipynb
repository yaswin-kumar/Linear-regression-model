   "id": "7bff6e57-d2bc-4b23-ac74-793de5461302",
   "metadata": {},
   "outputs": [],
   "source": [
    "def mean(x):\n",
    "    return np.sum(x)/len(x)\n",
    "    "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 140,
   "id": "6a70ece7-ea81-4756-8d8c-be8dfcfde5f2",
   "metadata": {},
   "outputs": [],
   "source": [
    "def variance(x):\n",
    "    mean_value = mean(x)\n",
    "    return np.sum((x-mean_value)**2)/len(x)\n",
    "    "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 141,
   "id": "4a8f034c-c408-4e90-88e7-dfc592de129d",
   "metadata": {},
   "outputs": [],
   "source": [
    "def norm(x):\n",
    "    mean_value = mean(x)\n",
    "    variance_value = variance(x)\n",
    "    return (x-mean_value)/np.sqrt(variance_value)"
   ]
  },
  {
   "cell_type": "code",
